    {
      "type": "image_picker",
      "id": "left_image_2",
      "label": "Left image 2"
    },
    {
      "type": "image_picker",
      "id": "left_image_3",
      "label": "Left image 3"
    },
    {
      "type": "image_picker",
      "id": "left_image_4",
      "label": "Left image 4"
    },
    {
      "type": "text",
      "id": "left_overlay_heading",
      "label": "Left overlay heading",
      "default": "BUNDLE DEAL"
    },
    {
      "type": "text",
      "id": "left_overlay_subtitle",
      "label": "Left overlay subtitle",
      "default": "SEA BALI STRAIGHT"
    },
    {
      "type": "url",
      "id": "left_link",
      "label": "Left area link"
    },
    {
      "type": "text",
      "id": "left_link_label",
      "label": "Left area accessible label",
      "default": "Open left bundle collection"
    },
    {
      "type": "header",
      "content": "Center column image"
    },
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "Center image"
    },
    {
      "type": "url",
      "id": "center_link",
      "label": "Center area link"
    },
    {
      "type": "text",
      "id": "center_link_label",
      "label": "Center area accessible label",
      "default": "Open center featured product"
    },
    {
      "type": "header",
      "content": "Right column images"
    },
    {
      "type": "image_picker",
      "id": "right_image_1",
      "label": "Right image 1"
    },
    {
      "type": "image_picker",
      "id": "right_image_2",
      "label": "Right image 2"
    },
    {
      "type": "image_picker",
      "id": "right_image_3",
      "label": "Right image 3"
    },
    {
      "type": "image_picker",
      "id": "right_image_4",
      "label": "Right image 4"
    },
    {
      "type": "text",
      "id": "right_overlay_heading",
      "label": "Right overlay heading",
      "default": "BUNDLE DEAL"
    },
    {
      "type": "text",
      "id": "right_overlay_subtitle",
      "label": "Right overlay subtitle",
      "default": "SEA ZEN STRAIGHT"
    },
    {
      "type": "url",
      "id": "right_link",
      "label": "Right area link"
    },
    {
      "type": "text",
      "id": "right_link_label",
      "label": "Right area accessible label",
      "default": "Open right bundle collection"
    },
    {
      "type": "header",
      "content": "Badge"
    },
    {
      "type": "checkbox",
      "id": "show_sale_badge",
      "label": "Show sale badge",
      "default": true
    },
    {
      "type": "text",
      "id": "sale_badge_text",
      "label": "Sale badge text",
