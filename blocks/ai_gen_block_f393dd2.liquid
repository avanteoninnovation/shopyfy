<bundle-showcase-{{ ai_gen_id }} class="ai-bundle-showcase-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-bundle-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.collection != blank %}
      <div class="ai-bundle-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-bundle-title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.collection != blank and block.settings.show_view_all %}
          <a href="{{ block.settings.collection.url }}" class="ai-view-all-{{ ai_gen_id }}">
            {{ block.settings.view_all_text }}
          </a>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-bundle-grid-{{ ai_gen_id }}">
      {% if block.settings.collection != blank %}
        {% for product in block.settings.collection.products limit: block.settings.products_to_show %}
          <div class="ai-bundle-card-{{ ai_gen_id }}">
            <a href="{{ product.url }}" class="ai-bundle-image-wrap-{{ ai_gen_id }}">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 800 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-bundle-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="{{ product.featured_image.width }}"
                  height="{{ product.featured_image.height }}"
                >
              {% else %}
                <div class="ai-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}

              {% if product.compare_at_price > product.price %}
                <div class="ai-sale-badge-{{ ai_gen_id }}">
                  {{ block.settings.sale_badge_text }}
                </div>
              {% endif %}

              {% if block.settings.show_overlay %}
                <div class="ai-image-overlay-{{ ai_gen_id }}">
                  <h3 class="ai-overlay-heading-{{ ai_gen_id }}">{{ block.settings.overlay_heading }}</h3>
                  {% if block.settings.overlay_subtitle != blank %}
                    <div class="ai-overlay-subtitle-{{ ai_gen_id }}">{{ block.settings.overlay_subtitle }}</div>
                  {% endif %}
                </div>
              {% endif %}
            </a>

            <div class="ai-product-information-{{ ai_gen_id }}">
              <a href="{{ product.url }}" class="ai-product-title-{{ ai_gen_id }}">
                {{ product.title }}
              </a>

              <div class="ai-price-row-{{ ai_gen_id }}">
                {% if product.compare_at_price > product.price %}
                  <span class="ai-compare-price-{{ ai_gen_id }}">{{ product.compare_at_price | money }}</span>
                {% endif %}
                <span class="ai-current-price-{{ ai_gen_id }}">{{ product.price | money }}</span>
                {% if product.compare_at_price > product.price %}
                  {% assign savings = product.compare_at_price | minus: product.price %}
                  <span class="ai-saving-{{ ai_gen_id }}">(Save {{ savings | money }})</span>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      {% else %}
        {% for i in (1..block.settings.products_to_show) %}
          <div class="ai-bundle-card-{{ ai_gen_id }}">
            <div class="ai-bundle-image-wrap-{{ ai_gen_id }}">
              <div class="ai-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
              {% if block.settings.show_overlay %}
                <div class="ai-image-overlay-{{ ai_gen_id }}">
                  <h3 class="ai-overlay-heading-{{ ai_gen_id }}">{{ block.settings.overlay_heading }}</h3>
                  {% if block.settings.overlay_subtitle != blank %}
                    <div class="ai-overlay-subtitle-{{ ai_gen_id }}">{{ block.settings.overlay_subtitle }}</div>
                  {% endif %}
                </div>
              {% endif %}
            </div>
            <div class="ai-product-information-{{ ai_gen_id }}">
              <span class="ai-product-title-{{ ai_gen_id }}">Product title</span>
              <div class="ai-price-row-{{ ai_gen_id }}">
                <span class="ai-current-price-{{ ai_gen_id }}">$0.00</span>
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</bundle-showcase-{{ ai_gen_id }}>

<script>
  (function() {
    class BundleShowcase{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('bundle-showcase-{{ ai_gen_id }}', BundleShowcase{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Bundle showcase",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Shop Bundles"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show view all button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View all button text",
      "default": "View All"
    },
    {
      "type": "text",
      "id": "sale_badge_text",
      "label": "Sale badge text",
      "default": "SALE"
    },
    {
      "type": "header",
      "content": "Image overlay"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show overlay",
      "default": true
    },
    {
      "type": "text",
      "id": "overlay_heading",
      "label": "Overlay heading",
      "default": "BUNDLE"
    },
    {
      "type": "text",
      "id": "overlay_subtitle",
      "label": "Overlay subtitle",
      "default": "Save More"
    },
    {
      "type": "color",
      "id": "overlay_background",
      "label": "Overlay background",
      "default": "rgba(0,0,0,0.6)"
    },
    {
      "type": "color",
      "id": "overlay_text_color",
      "label": "Overlay text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid gap",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "product_title_color",
      "label": "Product title",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "Bundle showcase"
    }
  ]
}
{% endschema %}
